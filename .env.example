# docparse environment variables (sample)
#
# Copy this file to ".env" and fill in only the keys for the parsers you use.
# Each parser under parsers/ is independent: if a key is missing, that parser
# prints an install/setup hint and the others keep working.
#
#   cp .env.example .env
#
# Never commit your real ".env" file. All values below are intentionally blank.

# --- LlamaParse v2 (parsers/llamaparse_parse.py) ---
# Primary parser for medium and larger PDFs (agentic tier).
# Get a key: https://cloud.llamaindex.ai/
LLAMAPARSE_API_KEY=

# --- Upstage Document Parse (parsers/upstage_parse.py) ---
# Baseline / cross-validation parser, strongest at completeness and metadata.
# Get a key: https://console.upstage.ai/
UPSTAGE_API_KEY=

# --- Google Gemini (parsers/gemini_parse.py, scripts/generate_alt_text.py) ---
# Small-PDF primary parser and alt-text generation.
# Get a key: https://aistudio.google.com/apikey
GEMINI_API_KEY=

# --- Mistral (parsers/mistral_parse.py) ---
# Three-way cross-validation, large-document completeness, non-Korean material.
# Get a key: https://console.mistral.ai/
MISTRAL_API_KEY=

# --- Corepin (parsers/corepin_parse.py) ---
# AI3 OSS engine router (multi-format single API), Korean filtering SLM.
# Get a key: https://corepin.ai/
COREPIN_API_KEY=

# --- Google Cloud Vision OCR (parsers/gvision_parse.py) ---
# Non-LLM OCR with per-word confidence, for handwriting / verbatim transcription.
# Use EITHER the API key below, OR the GV_TOKEN + GV_PROJECT pair further down.
# Get an API key: https://console.cloud.google.com/apis/credentials
# Enable the Vision API: https://console.cloud.google.com/apis/library/vision.googleapis.com
GOOGLE_VISION_API_KEY=

# Alternative Vision auth: OAuth access token + project id (instead of GOOGLE_VISION_API_KEY).
# GV_TOKEN is an access token, e.g. the output of: gcloud auth print-access-token
GV_TOKEN=
# GV_PROJECT is your Google Cloud project id.
GV_PROJECT=
